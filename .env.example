# Copy to `.env.local` (Next.js) and/or `.env` (Prisma CLI). Do not put real secrets in git.

# SQLite path is relative to the `prisma/` folder (see Prisma docs).
DATABASE_URL="file:./dev.db"

# Required for AI match + cover letters — set in Vercel Project → Settings → Environment Variables.
ANTHROPIC_API_KEY=

# Vercel: set Root Directory to `jobpulse`. SQLite on serverless is ephemeral; use a hosted DB for production.
